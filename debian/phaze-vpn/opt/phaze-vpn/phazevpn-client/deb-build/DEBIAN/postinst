#!/bin/bash
# Post-installation script for PhazeVPN Client
# Automatically adds repository for future updates

set -e

REPO_URL="https://phazevpn.duckdns.org/repo"
REPO_KEY_URL="${REPO_URL}/gpg-key.asc"
REPO_LIST="/etc/apt/sources.list.d/phazevpn.list"
REPO_KEY="/etc/apt/trusted.gpg.d/phazevpn.gpg"

echo "================================================================================"
echo "🔒 PhazeVPN Client - Installation Complete"
echo "================================================================================"
echo ""

# Check if running as root
if [ "$EUID" -ne 0 ]; then 
    echo "⚠️  Warning: Not running as root - repository setup skipped"
    exit 0
fi

# Add repository for automatic updates
echo "📦 Setting up automatic updates repository..."
echo ""

# Download and add GPG key
if [ ! -f "$REPO_KEY" ]; then
    echo "   Adding repository GPG key..."
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$REPO_KEY_URL" | gpg --dearmor -o "$REPO_KEY" 2>/dev/null || {
            echo "   ⚠️  Warning: Could not add GPG key automatically"
        }
    else
        echo "   ⚠️  Warning: curl not found, skipping GPG key setup"
    fi
fi

# Add repository to sources list
if [ ! -f "$REPO_LIST" ]; then
    echo "   Adding repository to package sources..."
    echo "deb ${REPO_URL} stable main" > "$REPO_LIST"
    chmod 644 "$REPO_LIST"
    echo "   ✅ Repository added"
else
    echo "   ✅ Repository already configured"
fi

# Update package list
echo "   Updating package list..."
apt-get update -qq 2>/dev/null || {
    echo "   ⚠️  Warning: Could not update package list"
}

echo ""
echo "================================================================================"
echo "✅ PhazeVPN Client Installed Successfully!"
echo "================================================================================"
echo ""
echo "🎉 Automatic updates are now configured!"
echo ""
echo "Future updates will appear in:"
echo "   • Ubuntu Software (Software Center)"
echo "   • Update Manager (Software Updater)"
echo "   • Package Manager"
echo ""
echo "To check for updates:"
echo "   sudo apt update && sudo apt upgrade"
echo ""
echo "Or just use Update Manager - it's automatic! ✨"
echo ""

# Fix permissions
chmod +x /usr/bin/phazevpn-client 2>/dev/null || true
chmod +x /usr/share/phazevpn-client/phazevpn-client.py 2>/dev/null || true

exit 0

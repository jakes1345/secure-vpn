#!/usr/bin/env python3
"""
PhazeVPN Unified Client & Dashboard
Launcher script
"""

import sys
from pathlib import Path

# Add client directory to path
client_dir = Path('/usr/share/phazevpn-client')
sys.path.insert(0, str(client_dir))

# Import and run unified client
try:
    from phazevpn_client import PhazeVPNUnified
    app = PhazeVPNUnified()
except ImportError:
    # Fallback to direct execution
    import subprocess
    subprocess.run([sys.executable, str(client_dir / 'phazevpn-client.py')])
